{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "",
  "description": "",
  "type": "object",
  "properties": {
    "AccountHolderName": {
      "allOf": [
        {
          "if": {
            "properties": {
              "AccountHolderType": {
                "const": "Individual"
              }
            }
          },
          "then": {
            "properties": {
              "Name": {
                "properties": {
                  "FirstName": {
                    "errorMessage": "First name must be between 3 and 32 characters",
                    "maxLength": 32,
                    "minLength": 3,
                    "title": "First name",
                    "type": "string"
                  },
                  "LastName": {
                    "errorMessage": "Last name must be between 3 and 32 characters",
                    "maxLength": 32,
                    "minLength": 3,
                    "title": "Last name",
                    "type": "string"
                  }
                },
                "required": ["FirstName", "LastName"],
                "title": "Full name",
                "type": "object",
                "x-total-max-length": 35,
                "x-validation-message": "Combined first and last name must not exceed 35 characters"
              }
            },
            "required": ["Name"]
          }
        },
        {
          "if": {
            "properties": {
              "AccountHolderType": {
                "const": "Business"
              }
            }
          },
          "then": {
            "properties": {
              "Name": {
                "errorMessage": "Name must be between 3 and 35 characters",
                "maxLength": 35,
                "minLength": 3,
                "title": "Business name",
                "type": "string"
              }
            },
            "required": ["Name"]
          }
        }
      ],
      "properties": {
        "AccountHolderType": {
          "enum": ["Individual", "Business"],
          "title": "Account holder type",
          "type": "string"
        }
      },
      "required": ["AccountHolderType"],
      "title": "Account holder name",
      "type": "object"
    },
